{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSH Manager",
  "version": "0.1.1",
  "identifier": "com.hbseo.sshmanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SSH Manager",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "hbseo",
    "copyright": "© 2026 hbseo",
    "category": "DeveloperTool",
    "shortDescription": "SSH 프로필 관리자",
    "longDescription": "프로필을 저장하고 원클릭으로 SSH 세션을 여는 데스크톱 앱",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["Korean", "English"],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp"
      },
      "wix": {
        "language": ["ko-KR", "en-US"]
      }
    }
  }
}
